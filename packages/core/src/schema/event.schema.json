{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hive-exp.dev/schema/event.schema.json",
  "title": "Hive Event Envelope",
  "oneOf": [
    {
      "$ref": "#/definitions/experienceCreatedEvent"
    },
    {
      "$ref": "#/definitions/experienceReferencedEvent"
    },
    {
      "$ref": "#/definitions/experienceOutcomeRecordedEvent"
    },
    {
      "$ref": "#/definitions/experiencePromotedEvent"
    },
    {
      "$ref": "#/definitions/experienceProvisionalEvent"
    },
    {
      "$ref": "#/definitions/experienceProvisionalExpiredEvent"
    },
    {
      "$ref": "#/definitions/experienceArchivedEvent"
    },
    {
      "$ref": "#/definitions/experienceQuarantinedEvent"
    },
    {
      "$ref": "#/definitions/experienceSupersededEvent"
    },
    {
      "$ref": "#/definitions/confidenceDecayedEvent"
    },
    {
      "$ref": "#/definitions/strategyBannedEvent"
    }
  ],
  "definitions": {
    "eventEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^evt_\\d+_[a-f0-9]{8}$"
        },
        "type": {
          "type": "string",
          "enum": [
            "experience.created",
            "experience.referenced",
            "experience.outcome_recorded",
            "experience.promoted",
            "experience.provisional",
            "experience.provisional_expired",
            "experience.archived",
            "experience.quarantined",
            "experience.superseded",
            "confidence.decayed",
            "strategy.banned"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "source_agent": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string",
          "pattern": "^(hmac-sha256|ed25519):.+$"
        },
        "payload": {
          "type": "object"
        }
      },
      "required": [
        "event_id",
        "type",
        "timestamp",
        "source_agent",
        "signature",
        "payload"
      ]
    },
    "expId": {
      "type": "string",
      "pattern": "^exp_\\d+_[a-f0-9]{8}$"
    },
    "evtId": {
      "type": "string",
      "pattern": "^evt_\\d+_[a-f0-9]{8}$"
    },
    "experienceCreatedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "initial_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "exp_id",
        "initial_confidence"
      ]
    },
    "experienceReferencedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "context_summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "exp_id",
        "context_summary"
      ]
    },
    "experienceOutcomePayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "ref_event_id": {
          "$ref": "#/definitions/evtId"
        },
        "result": {
          "type": "string",
          "enum": [
            "success",
            "failed",
            "partial"
          ]
        }
      },
      "required": [
        "exp_id",
        "ref_event_id",
        "result"
      ]
    },
    "experiencePromotedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "promoted_by": {
          "const": "human"
        }
      },
      "required": [
        "exp_id",
        "promoted_by"
      ]
    },
    "experienceProvisionalPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "consensus_agents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deadline": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "exp_id",
        "consensus_agents",
        "deadline"
      ]
    },
    "experienceProvisionalExpiredPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        }
      },
      "required": [
        "exp_id"
      ]
    },
    "experienceArchivedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "reason": {
          "type": "string",
          "enum": [
            "zero_ref",
            "low_confidence",
            "consecutive_fail"
          ]
        }
      },
      "required": [
        "exp_id",
        "reason"
      ]
    },
    "experienceQuarantinedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exp_id": {
          "$ref": "#/definitions/expId"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "exp_id",
        "reason"
      ]
    },
    "experienceSupersededPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "old_exp_id": {
          "$ref": "#/definitions/expId"
        },
        "new_exp_id": {
          "$ref": "#/definitions/expId"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "old_exp_id",
        "new_exp_id",
        "reason"
      ]
    },
    "confidenceDecayedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "affected_exp_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/expId"
          }
        },
        "decay_factor": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "affected_exp_ids",
        "decay_factor"
      ]
    },
    "strategyBannedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy_name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "banned_by": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "strategy_name",
        "reason",
        "banned_by"
      ]
    },
    "experienceCreatedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.created"
            },
            "payload": {
              "$ref": "#/definitions/experienceCreatedPayload"
            }
          }
        }
      ]
    },
    "experienceReferencedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.referenced"
            },
            "payload": {
              "$ref": "#/definitions/experienceReferencedPayload"
            }
          }
        }
      ]
    },
    "experienceOutcomeRecordedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.outcome_recorded"
            },
            "payload": {
              "$ref": "#/definitions/experienceOutcomePayload"
            }
          }
        }
      ]
    },
    "experiencePromotedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.promoted"
            },
            "payload": {
              "$ref": "#/definitions/experiencePromotedPayload"
            }
          }
        }
      ]
    },
    "experienceProvisionalEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.provisional"
            },
            "payload": {
              "$ref": "#/definitions/experienceProvisionalPayload"
            }
          }
        }
      ]
    },
    "experienceProvisionalExpiredEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.provisional_expired"
            },
            "payload": {
              "$ref": "#/definitions/experienceProvisionalExpiredPayload"
            }
          }
        }
      ]
    },
    "experienceArchivedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.archived"
            },
            "payload": {
              "$ref": "#/definitions/experienceArchivedPayload"
            }
          }
        }
      ]
    },
    "experienceQuarantinedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.quarantined"
            },
            "payload": {
              "$ref": "#/definitions/experienceQuarantinedPayload"
            }
          }
        }
      ]
    },
    "experienceSupersededEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "experience.superseded"
            },
            "payload": {
              "$ref": "#/definitions/experienceSupersededPayload"
            }
          }
        }
      ]
    },
    "confidenceDecayedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "confidence.decayed"
            },
            "payload": {
              "$ref": "#/definitions/confidenceDecayedPayload"
            }
          }
        }
      ]
    },
    "strategyBannedEvent": {
      "allOf": [
        {
          "$ref": "#/definitions/eventEnvelope"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "strategy.banned"
            },
            "payload": {
              "$ref": "#/definitions/strategyBannedPayload"
            }
          }
        }
      ]
    }
  }
}
